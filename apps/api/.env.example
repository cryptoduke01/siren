# Siren API — copy to .env and fill. See docs/GETTING_STARTED.md for how to get each key.
# NEVER commit .env or share it — it contains secrets.
PORT=4000
NODE_ENV=development

# Redis (for velocity cache + BullMQ)
REDIS_URL=redis://localhost:6379

# Postgres
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/siren

# Kalshi — https://kalshi.com (API key + RSA private key for signing)
KALSHI_API_KEY=
KALSHI_PRIVATE_KEY=

# DFlow — x-api-key header required; production endpoints only with key
# Production: e.prediction-markets-api.dflow.net, e.quote-api.dflow.net
# Geo-fence US + restricted Kalshi jurisdictions for trading; see lib/geo-fence.ts
DFLOW_API_KEY=
DFLOW_METADATA_API_URL=https://e.prediction-markets-api.dflow.net
DFLOW_QUOTE_API_URL=https://e.quote-api.dflow.net

# Bags — https://dev.bags.fm (API key + partner config for fee share)
BAGS_API_KEY=
BAGS_PARTNER_CONFIG_KEY=
BAGS_REF_URL=

# Twitter — developer.x.com (optional, for CT signal layer)
TWITTER_BEARER_TOKEN=

# DexScreener — no key required; base URL (https://api.dexscreener.com)
DEXSCREENER_BASE_URL=https://api.dexscreener.com

# Jupiter — https://portal.jup.ag/api-keys (Basic: api.jup.ag, Ultra: api.jup.ag/ultra)
JUPITER_API_KEY=

# Supabase — waitlist storage (Settings > API: url + service_role key)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Access code for terminal on production (onsiren.xyz). Web app validates via API.
SIREN_ACCESS_CODE=
