NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_WS_URL=ws://localhost:4000/ws

# Privy (social auth + embedded Solana / EVM wallets) — dashboard.privy.io
NEXT_PUBLIC_PRIVY_APP_ID=

# Optional: server-side (e.g. for API auth)
# PRIVY_APP_SECRET=

# Required for swaps in production — public RPC returns 403 on sendTransaction
# Helius: https://mainnet.helius-rpc.com/?api-key=YOUR_HELIUS_KEY
# NEXT_PUBLIC_SOLANA_RPC_URL=

# Optional: admin panel passcode (/admin)
# NEXT_PUBLIC_ADMIN_PASSCODE=

# Optional: set to false to disable terminal access gate
# SIREN_GATE_ENABLED=false
