NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_WS_URL=ws://localhost:4000/ws
# Optional: custom Solana RPC (avoids 403 from public mainnet-beta). e.g. https://mainnet.helius-rpc.com/?api-key=YOUR_KEY
# Optional: force terminal gate on any host (set to true on Vercel for production)
SIREN_GATE_ENABLED=true
